{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "reporting-live-agents",
  "main": "src/worker.ts",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI"
  },
  "durable_objects": {
    "bindings": [
      { "name": "SOUNDSCAPE_AGENT", "class_name": "SoundscapeAgent" },
      { "name": "ANCHOR_AGENT", "class_name": "AnchorAgent" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["SoundscapeAgent", "AnchorAgent"] }
  ]
}

